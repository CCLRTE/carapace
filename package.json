{
  "name": "@cclrte/carapace",
  "version": "0.2.0",
  "description": "Deterministic scenarios and verification for real application interfaces.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "packageManager": "bun@1.3.14",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CCLRTE/carapace.git"
  },
  "homepage": "https://github.com/CCLRTE/carapace#readme",
  "bugs": {
    "url": "https://github.com/CCLRTE/carapace/issues"
  },
  "keywords": [
    "typescript",
    "frontend-testing",
    "deterministic-testing",
    "fixtures",
    "scenario-testing",
    "property-testing"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./src/core/index.ts",
      "import": "./dist/core/index.js"
    },
    "./react": {
      "types": "./src/react.ts",
      "import": "./dist/react.js"
    },
    "./testing": {
      "types": "./src/testing/index.ts",
      "import": "./dist/testing/index.js"
    },
    "./web": {
      "types": "./src/web.ts",
      "import": "./dist/web.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "files": [
    "dist",
    "src/core/coverage.ts",
    "src/core/definition.ts",
    "src/core/effects.ts",
    "src/core/fixture.ts",
    "src/core/ids.ts",
    "src/core/index.ts",
    "src/core/json-value.ts",
    "src/core/json.ts",
    "src/core/query.ts",
    "src/core/reason.ts",
    "src/core/resource.ts",
    "src/core/result.ts",
    "src/core/runtime.ts",
    "src/core/scenario.ts",
    "src/core/store.ts",
    "src/index.ts",
    "src/react.ts",
    "src/testing/activity.ts",
    "src/testing/index.ts",
    "src/testing/probe.ts",
    "src/testing/scripted-transport.ts",
    "src/testing/session.ts",
    "src/web.ts",
    "src/web/browser-bridge.ts",
    "src/web/fetch-firewall.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun -e 'await (await import(\"node:fs/promises\")).rm(\"./dist\", { recursive: true, force: true })' && bun build ./src/index.ts ./src/core/index.ts ./src/react.ts ./src/testing/index.ts ./src/web.ts --outdir ./dist --root ./src --target browser --format esm --splitting --packages external",
    "typecheck": "tsc --noEmit",
    "test": "bun test ./src",
    "example:build": "vite build --config examples/todos/vite.config.ts",
    "example:build:carapace": "vite build --config examples/todos/carapace/vite.config.ts",
    "example:carapace": "vite --config examples/todos/carapace/vite.config.ts",
    "example:check-boundary": "bun run examples/todos/carapace/check-production-boundary.ts examples/todos/dist",
    "example:dev": "vite --config examples/todos/vite.config.ts",
    "example:react-native": "bun run --cwd examples/react-native start",
    "example:react-native:test": "bun run --cwd examples/react-native test",
    "example:react-native:typecheck": "tsc -p examples/react-native/tsconfig.json --noEmit",
    "example:react-native:verify": "bun run examples/react-native/verify.ts",
    "example:test": "bun test ./examples/todos",
    "example:typecheck": "tsc -p examples/todos/tsconfig.json --noEmit",
    "example:verify": "bun run examples/todos/verify.ts",
    "lint": "eslint src examples scripts",
    "test:package": "bun run ./scripts/package-smoke.ts",
    "check": "bun run typecheck && bun run test && bun run build && bun run lint && bun run example:test && bun run example:typecheck && bun run example:verify && bun run example:react-native:test && bun run example:react-native:typecheck && bun run example:react-native:verify && bun run test:package",
    "prepack": "bun run check"
  },
  "peerDependencies": {
    "react": ">=18 <20"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@expo/metro-runtime": "~57.0.6",
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9.39.2",
    "expo": "~57.0.7",
    "fast-check": "^4.8.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-web": "~0.21.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.53.0",
    "vite": "^8.1.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
